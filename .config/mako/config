# Appearance
# Match Hyprland rounding = 5
border-radius=5

# Match Hyprland border_size = 2
border-size=2

# Font Selection
font=JetBrainsMono Nerd Font 10

# Colors
# Match Hyprland col.active_border (33ccffee)
border-color=#33ccffee
# Match Hyprland shadow color (1a1a1aee) for background
background-color=#1a1a1a00
text-color=#ffffff

# Layout
# Match Hyprland gaps_out = 10
margin=10
padding=10
default-timeout=5000

# Transparency/Opacity
# Match Hyprland active_opacity = 1.0
# Note: Handled via the hex alpha channel in background-color (ee)

[urgency=low]
default-timeout=0
layer=overlay

[urgency=critical]
default-timeout=0
layer=overlay
